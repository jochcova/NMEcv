Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"k", "=", "n"}], ",", 
    RowBox[{"k", ">=", "1"}], ",", 
    RowBox[{"k", "--"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"suma", "=", "0"}], ";", " ", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"j", "=", 
        RowBox[{"k", "+", "1"}]}], ",", 
       RowBox[{"j", "<=", "n"}], ",", 
       RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"suma", "=", 
         RowBox[{"suma", "+", 
          RowBox[{
           RowBox[{"x", "[", 
            RowBox[{"[", "j", "]"}], "]"}], "*", 
           RowBox[{"A", "[", 
            RowBox[{"[", 
             RowBox[{"k", ",", "j"}], "]"}], "]"}]}]}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"x", "[", 
       RowBox[{"[", "k", "]"}], "]"}], "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"b", "[", 
          RowBox[{"[", "k", "]"}], "]"}], "-", "suma"}], ")"}], "/", 
       RowBox[{"A", "[", 
        RowBox[{"[", 
         RowBox[{"k", ",", "k"}], "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"x", "[", 
       RowBox[{"[", "k", "]"}], "]"}], "]"}]}]}], "\[IndentingNewLine]", 
   "]"}], 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
     "algoritmus", " ", "postupuje", " ", "od", " ", 
      "nejv\[EHacek]t\[SHacek]\[IAcute]ho", " ", "indexu", " ", "k"}], "=", 
     "n"}], ",", " ", 
    RowBox[{"inkrement", " ", "se", " ", "zmen\[SHacek]uje"}]}], 
   "*)"}]}]], "Input",
