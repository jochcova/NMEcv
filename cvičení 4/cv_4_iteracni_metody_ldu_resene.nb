Cell["Jacobiho metoda", "Text",
 CellFrame->{{0, 0}, {0, 0}},
 CellChangeTimes->{{3.9194122122054896`*^9, 3.9194122164397826`*^9}},
 Background->RGBColor[
  1, 0.925, 0.925],ExpressionUUID->"dcee47f4-a76a-4161-86b2-70a52610a6e9"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"xj", "=", 
    RowBox[{"{", "}"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "zde", " ", "budu", " ", "ukl\[AAcute]dat", " ", 
    "\[RHacek]e\[SHacek]en\[IAcute]"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"x", "=", "x0"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "po\[CHacek]\[AAcute]te\[CHacek]n\[IAcute]", " ", "odhad", " ", 
    "\[RHacek]e\[SHacek]en\[IAcute]"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", "1"}], ",", 
   RowBox[{"i", "<=", "100"}], ",", 
   RowBox[{"i", "++"}], ",", " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"x", "=", 
     RowBox[{
      RowBox[{"Inverse", "[", "d", "]"}], ".", 
      RowBox[{"(", 
       RowBox[{"b", "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"l", "+", "u"}], ")"}], ".", "x"}]}], ")"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"xj", ",", "x"}], "]"}], ";"}]}], "\[IndentingNewLine]", 
  "]"}], "\[IndentingNewLine]", "x"}], "Input",
 CellChangeTimes->{{3.919336103479355*^9, 3.919336125349472*^9}, 
   3.9505967768239503`*^9, {3.9821368293679004`*^9, 3.98213683184581*^9}, {
   3.982136968606394*^9, 3.9821369801914663`*^9}, {3.982138795158698*^9, 
   3.982138817019331*^9}, {3.982139068020523*^9, 3.982139070003947*^9}, {
   3.982139146576474*^9, 3.982139181188142*^9}, {3.9833514256840343`*^9, 
   3.983351446107394*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"6340f2cd-f780-475e-acbe-7a872589b898"],

Cell["Gauss-Seidelova metoda", "Text",
 CellFrame->{{0, 0}, {0, 0}},
 CellChangeTimes->{{3.9194123565013733`*^9, 3.9194123850792217`*^9}},
 Background->RGBColor[
  0.87, 0.94, 1],ExpressionUUID->"3ee48600-b11c-4e29-9ad6-611c03d1253a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"xg", "=", 
    RowBox[{"{", "}"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "zde", " ", "budu", " ", "ukl\[AAcute]dat", " ", 
    "\[RHacek]e\[SHacek]en\[IAcute]"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"x", "=", "x0"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "po\[CHacek]\[AAcute]te\[CHacek]n\[IAcute]", " ", "odhad", " ", 
    "\[RHacek]e\[SHacek]en\[IAcute]"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", "1"}], ",", 
   RowBox[{"i", "<=", "100"}], ",", 
   RowBox[{"i", "++"}], ",", " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"x", "=", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{
        RowBox[{"Inverse", "[", 
         RowBox[{"l", "+", "d"}], "]"}], ".", "u", ".", "x"}]}], "+", 
      RowBox[{
       RowBox[{"Inverse", "[", 
        RowBox[{"l", "+", "d"}], "]"}], ".", "b"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"xg", ",", "x"}], "]"}], ";"}]}], "\[IndentingNewLine]", 
  "]"}], "\[IndentingNewLine]", "x"}], "Input",
 CellChangeTimes->{{3.9833517337511406`*^9, 3.98335178932796*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"d200d0d6-1bcb-4445-bac5-64f1cda12d84"],

Cell["Superrelaxa\[CHacek]n\[IAcute] metoda", "Text",
 CellFrame->{{0, 0}, {0, 0}},
 CellChangeTimes->{{3.91941243398529*^9, 3.9194124423289323`*^9}},
 Background->RGBColor[
  0.88, 1, 0.88],ExpressionUUID->"c40ae90d-b2a4-4116-af6a-ed161b74dbb4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"f", "=", 
   RowBox[{"-", 
    RowBox[{
     RowBox[{"Inverse", "[", 
      RowBox[{"l", "+", "d"}], "]"}], ".", "u"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"g", "=", 
   RowBox[{"Inverse", "[", 
    RowBox[{"l", "+", "d"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"x", "=", "x0"}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"omega", "=", "2"}], ";"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"omega", "=", 
  RowBox[{"2", "/", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"1", "-", 
       RowBox[{
        RowBox[{"Max", "[", 
         RowBox[{"Abs", "[", 
          RowBox[{"Eigenvalues", "[", "f", "]"}], "]"}], "]"}], "^", "2"}]}], 
      "]"}]}], ")"}]}]}]}], "Input",
 CellChangeTimes->{{3.983351897079146*^9, 3.983351917025201*^9}, {
  3.9833520718287706`*^9, 3.9833521671020327`*^9}},
 CellLabel->"In[59]:=",ExpressionUUID->"8ccacafd-bd1f-4610-acec-a50f48984b13"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"xs", "=", 
    RowBox[{"{", "}"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "zde", " ", "budu", " ", "ukl\[AAcute]dat", " ", 
    "\[RHacek]e\[SHacek]en\[IAcute]"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"x", "=", "x0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", "1"}], ",", 
   RowBox[{"i", "<=", "100"}], ",", 
   RowBox[{"i", "++"}], ",", " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xkp1", "=", 
     RowBox[{
      RowBox[{"f", ".", "x"}], "+", 
      RowBox[{"g", ".", "b"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"x", "=", 
     RowBox[{
      RowBox[{"omega", "*", 
       RowBox[{"(", 
        RowBox[{"xkp1", "-", "x"}], ")"}]}], "+", "x"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"xs", ",", "x"}], "]"}], ";"}]}], "\[IndentingNewLine]", 
  "]"}], "\[IndentingNewLine]", "x"}], "Input",
 CellChangeTimes->{{3.9833519712321224`*^9, 3.9833519984655666`*^9}},
 CellLabel->"In[63]:=",ExpressionUUID->"3c604d2c-8d1f-4696-b09b-5c9fc6e64d31"],

Cell[BoxData[
 RowBox[{"ListLogPlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Abs", "[", 
        RowBox[{
