   RowBox[{"LabelStyle", "->", "Large"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellChangeTimes->{{3.9833514996761928`*^9, 3.9833516712469807`*^9}, {
   3.98335181288899*^9, 3.983351822080535*^9}, {3.983352040037619*^9, 
